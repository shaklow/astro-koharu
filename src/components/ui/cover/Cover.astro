---
import { Routes } from '@constants/router';
import { createArticleStatsConfig, headerImages, siteConfig } from '@constants/site-config';
import { getPostReadingTime } from '@lib/content/posts';
import { displayDate } from '@lib/date';
import { getLqipStyle } from '@lib/lqip';
import { routeBuilder } from '@lib/route';
import { Icon } from 'astro-icon/components';
import type { BlogPost } from 'types/blog';
import UmamiPVSpan from '@/components/umami/UmamiPVSpan';
import { MAX_WIDTH } from '@/constants/layout';
import { getLocaleFromUrl, localizedPath, t } from '@/i18n';
import WaveSvg from './wave';

export interface CoverProps {
  data?: BlogPost;
  title?: string;
}

const { data, title } = Astro.props as CoverProps;

const { date, updated, title: dataTitle, draft } = data?.data ?? {};

const readState = data ? getPostReadingTime(data) : null;
const isDraft = import.meta.env.DEV && draft === true;

// --- Header image rotation ---
const SHOW_DURATION = 6; // seconds fully visible per image
const FADE_DURATION = 2; // crossfade overlap (fade-out and fade-in happen simultaneously)
const SLOT_GAP = SHOW_DURATION; // interval between adjacent images' fade-in start
const TOTAL_CYCLE = (headerImages.length - 1) * SLOT_GAP + SHOW_DURATION + FADE_DURATION;
const isMultiImage = headerImages.length > 1;

/** Derive responsive srcset from a single image path */
function srcsetAttr(path: string): string | null {
  if (path.includes('_1920')) {
    return `${path.replace('_1920', '_800')} 800w, ${path} 1200w`;
  }
  if (!path.includes('_800') && path.endsWith('.webp')) {
    const base = path.replace(/\.webp$/, '');
    return `${base}_800.webp 800w, ${path} 1200w`;
  }
  return null;
}

/** Generate CSS @keyframes for header image crossfade */
function headerKeyframesCSS(): string {
  if (!isMultiImage) return '';

  return headerImages
    .map((_, i) => {
      // Each image occupies a SLOT_GAP interval.
      // Fade-in and fade-out overlap with adjacent images' transitions.
      const fadeInEnd = i * SLOT_GAP + FADE_DURATION;
      const fadeOutStart = i * SLOT_GAP + SHOW_DURATION;
      const slotEnd = fadeOutStart + FADE_DURATION;
      const pct = (t: number) => ((t / TOTAL_CYCLE) * 100).toFixed(1);

      const keyframes = [`@keyframes headerFade${i} {`];

      if (i === 0) {
        // Image 0: starts visible; fade-out in its slot; wrap-around fade-in
        // at the end of the cycle (overlaps last image's fade-out)
        const wrapFadeIn = TOTAL_CYCLE - FADE_DURATION;
        keyframes.push(
          `  0% { opacity: 1; }`,
          `  ${pct(fadeOutStart)}% { opacity: 1; }`,
          `  ${pct(slotEnd)}% { opacity: 0; }`,
          `  ${pct(wrapFadeIn)}% { opacity: 0; }`,
          `  100% { opacity: 1; }`,
        );
      } else {
        keyframes.push(
          `  0% { opacity: 0; }`,
          `  ${pct(i * SLOT_GAP)}% { opacity: 0; }`,
          `  ${pct(fadeInEnd)}% { opacity: 1; }`,
          `  ${pct(fadeOutStart)}% { opacity: 1; }`,
          `  ${pct(slotEnd)}% { opacity: 0; }`,
          `  100% { opacity: 0; }`,
        );
      }

      keyframes.push('}');
      return keyframes.join('\n');
    })
    .join('\n');
}

// Pre-compute keyframes CSS string (is:inline on <style> is unreliable with dynamic content)
const headerKeyframesCss = headerKeyframesCSS();
const styleTag = headerKeyframesCss ? `<style>${headerKeyframesCss}</style>` : '';

// LQIP for the first header image
const bannerLqipStyle = getLqipStyle(headerImages[0]);

const locale = getLocaleFromUrl(Astro.url.pathname);

const href = data && localizedPath(routeBuilder(Routes.Post, data), locale);

const pageStatsConfig = href ? createArticleStatsConfig(href) : null;
---

<div class="relative flex h-[60dvh] z-0 max-h-200 overflow-hidden">
  <div class="absolute inset-0 h-full bg-black/40"></div>
  <div class="absolute inset-0 bottom-[8dvh] flex flex-col items-center justify-center px-5 text-white">
    {
      title ? (
        <h1
          class={`shadow-text word-break flex items-center gap-2 text-center text-5xl/[1.2] font-bold tracking-widest ${MAX_WIDTH.content}`}
        >
          {title}
          <Icon
            name="ri:link"
            title={t(locale, "cover.copyLink")}
            class="hover:text-primary cursor-pointer transition-colors duration-300"
            onclick="navigator.clipboard.writeText(window.location.href)"
          />
        </h1>
      ) : data ? (
        <>
          <h1
            class={`shadow-text word-break text-4.5xl text-center font-bold md:text-2xl ${MAX_WIDTH.content} flex flex-wrap items-center justify-center gap-3`}
          >
            {dataTitle ?? title}
            {isDraft && (
              <span class="inline-flex items-center gap-1.5 rounded-full bg-yellow-500 px-3 py-1.5 text-base font-semibold text-white shadow-lg backdrop-blur-sm text-shadow-none hover:bg-yellow-500 md:px-2.5 md:py-1 md:text-sm">
                <Icon name="fa6-solid:file-pen" class="h-4 w-4 md:h-3.5 md:w-3.5" />
                {t(locale, 'post.draft')}
              </span>
            )}
          </h1>
          {data && (
            <p class="mt-3 flex flex-wrap items-center justify-center gap-4 md:text-xs">
              <span class="flex items-center gap-1">
                <Icon name="fa6-solid:calendar-days" />
                {t(locale, "post.publishedAt", { date: date && displayDate.datetime(date) })}
              </span>
              {updated && (
                <span class="flex items-center gap-1">
                  <Icon name="fa6-solid:calendar-days" />
                  {t(locale, "post.updatedAt", { date: displayDate.datetime(updated) })}
                </span>
              )}
              <span class="flex items-center gap-1">
                <Icon name="fa6-solid:pen-nib" /> {t(locale, "post.wordCount", { count: readState?.words })}
              </span>
              <span class="flex items-center gap-1">
                <Icon name="fa6-solid:clock" />
                {readState?.text}
              </span>
              {pageStatsConfig && (
                <span class="flex items-center gap-1">
                  <Icon name="ri:eye-line" class="h-4 w-4" />
                  <UmamiPVSpan client:idle statsConfig={pageStatsConfig} />
                  {t(locale, 'stats.pageviews')}
                </span>
              )}
            </p>
          )}
        </>
      ) : (
        <>
          <h2 class="shadow-text font-chill-round text-5xl/[1.2]">{siteConfig?.alternate}</h2>
          <h1 class="shadow-text font-chill-round mt-3 text-5xl/[1.2] font-bold tracking-widest">{siteConfig?.title}</h1>
          <p class="shadow-text mt-5 text-sm">= {siteConfig?.subtitle} =</p>
        </>
      )
    }
  </div>
  <div
    class="relative -z-10 h-full min-h-60 w-full"
    transition:persist="page-cover-banner"
    id="banner-box"
    style={bannerLqipStyle}
  >
    {headerImages.map((img, i) => {
      const srcset = srcsetAttr(img);
      return (
        <img
          src={img}
          alt="cover"
          class="h-full w-full object-cover"
          class:list={[{ 'absolute inset-0': isMultiImage }]}
          sizes="50vw"
          {...(srcset ? { srcset } : {})}
          style={isMultiImage ? `animation: headerFade${i} ${TOTAL_CYCLE}s infinite` : undefined}
          loading="eager"
          fetchpriority={i === 0 ? 'high' : 'low'}
          decoding="async"
        />
      );
    })}
  </div>
  <WaveSvg />
</div>

<Fragment set:html={styleTag} />
